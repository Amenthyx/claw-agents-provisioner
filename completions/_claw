#compdef claw.sh claw

# =============================================================================
# _claw -- Zsh tab completion for claw.sh CLI
# =============================================================================
#
# Installation:
#   Option 1: Copy to a directory in your $fpath:
#     cp _claw /usr/local/share/zsh/site-functions/_claw
#     # or for per-user:
#     mkdir -p ~/.zsh/completions
#     cp _claw ~/.zsh/completions/_claw
#     # then add to .zshrc:  fpath=(~/.zsh/completions $fpath)
#
#   Option 2: Use the built-in installer:
#     ./claw.sh completions install
#
# =============================================================================

# -------------------------------------------------------------------------
# Helper: complete agent names
# -------------------------------------------------------------------------
_claw_agents() {
    local agents=(
        'zeroclaw:Rust agent (512 MB, port 3100)'
        'nanoclaw:TypeScript agent with DooD (1 GB, port 3200)'
        'picoclaw:Go edge/IoT agent (128 MB, port 3300)'
        'openclaw:Node.js full-featured agent (4 GB, port 3400)'
        'parlant:Python guideline-driven agent (2 GB, port 8800)'
    )
    _describe 'agent' agents
}

# -------------------------------------------------------------------------
# Helper: complete agent names plus "all"
# -------------------------------------------------------------------------
_claw_agents_or_all() {
    local agents=(
        'zeroclaw:Rust agent (512 MB, port 3100)'
        'nanoclaw:TypeScript agent with DooD (1 GB, port 3200)'
        'picoclaw:Go edge/IoT agent (128 MB, port 3300)'
        'openclaw:Node.js full-featured agent (4 GB, port 3400)'
        'parlant:Python guideline-driven agent (2 GB, port 8800)'
        'all:All agents'
    )
    _describe 'agent' agents
}

# -------------------------------------------------------------------------
# Helper: complete deployment methods for agent commands
# -------------------------------------------------------------------------
_claw_agent_methods() {
    local methods=(
        'docker:Start agent via Docker Compose'
        'vagrant:Start agent via Vagrant VM'
        'destroy:Teardown agent (remove containers/VMs/volumes)'
    )
    _describe 'method' methods
}

# -------------------------------------------------------------------------
# Subcommand: vault
# -------------------------------------------------------------------------
_claw_vault() {
    local -a subcmds=(
        'init:Create a new encrypted secrets vault'
        'import-env:Import .env keys into the vault'
        'list:List stored secret names'
        'get:Retrieve a secret value'
        'set:Store a secret (key value)'
        'rotate:Change vault password'
        'export-env:Export secrets back to .env format'
    )
    _arguments '1:subcommand:_describe "vault command" subcmds' \
               '2::argument:_files'
}

