# -------------------------------------------------------------------------
# Subcommand: rag
# -------------------------------------------------------------------------
_claw_rag() {
    local -a subcmds=(
        'start:Start RAG pipeline service (default port 9097)'
        'stop:Stop the RAG service'
        'status:Show RAG service status'
        'ingest:Ingest documents into RAG index'
        'search:Search the RAG index'
        'clear:Clear the RAG index'
    )

    case "${words[3]}" in
        ingest)
            _arguments '1:subcommand:_describe "rag command" subcmds' \
                       '2::path:_files' \
                       '3::agent:_claw_agents'
            ;;
        search)
            _arguments '1:subcommand:_describe "rag command" subcmds' \
                       '2::query:' \
                       '3::agent:_claw_agents'
            ;;
        clear)
            _arguments '1:subcommand:_describe "rag command" subcmds' \
                       '2::agent:_claw_agents'
            ;;
        *)
            _arguments '1:subcommand:_describe "rag command" subcmds'
            ;;
    esac
}

# -------------------------------------------------------------------------
# Subcommand: billing
# -------------------------------------------------------------------------
_claw_billing() {
    local -a subcmds=(
        'report:Cost report (daily, weekly, monthly)'
        'status:Current spend overview'
        'forecast:Projected spend forecast'
        'init:Initialize billing config'
        'threshold:Set spending alert threshold'
    )
    local -a periods=(daily weekly monthly)

    case "${words[3]}" in
        report)
            _arguments '1:subcommand:_describe "billing command" subcmds' \
                       '2::period:_describe "period" periods'
            ;;
        *)
            _arguments '1:subcommand:_describe "billing command" subcmds' \
                       '2::argument:'
            ;;
    esac
}

# -------------------------------------------------------------------------
# Subcommand: skills
# -------------------------------------------------------------------------
_claw_skills() {
    local -a subcmds=(
        'list:List all available skills'
        'search:Search skills catalog'
        'install:Install skill for an agent'
        'uninstall:Uninstall skill from an agent'
        'bundle:Install skill bundle for an agent'
        'installed:List installed skills'
        'info:Show skill details'
        'bundles:List available bundles'
    )

    case "${words[3]}" in
        install|uninstall|bundle)
            _arguments '1:subcommand:_describe "skills command" subcmds' \
                       '2::skill ID:' \
                       '3::agent:_claw_agents'
            ;;
        installed)
            _arguments '1:subcommand:_describe "skills command" subcmds' \
                       '2::agent:_claw_agents'
            ;;
        *)
            _arguments '1:subcommand:_describe "skills command" subcmds' \
                       '2::argument:'
            ;;
    esac
}

