        'check-url:Test a URL against rules'
        'check-content:Test content against rules'
        'check-ip:Test an IP against rules'
        'generate-prompt:Generate system prompt security appendix'
        'validate:Validate security configuration'
    )
    _arguments '1:subcommand:_describe "security command" subcmds' \
               '2::argument:'
}

