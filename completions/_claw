        'info:Show adapter details'
        'search:Search adapters'
    )
    _arguments '1:subcommand:_describe "adapter command" subcmds' \
               '2::argument:'
}

# -------------------------------------------------------------------------
# Main completion function
# -------------------------------------------------------------------------
_claw() {
    local -a top_commands=(
        # Agent platforms
        'zeroclaw:Start/manage Rust agent (512 MB, port 3100)'
        'nanoclaw:Start/manage TypeScript agent (1 GB, port 3200)'
        'picoclaw:Start/manage Go edge agent (128 MB, port 3300)'
        'openclaw:Start/manage Node.js agent (4 GB, port 3400)'
        'parlant:Start/manage Python agent (2 GB, port 8800)'

        # Deployment
        'deploy:Assessment-driven deployment pipeline'
        'validate:Validate assessment JSON schema'

        # Fine-tuning
        'finetune:Generate dataset and train LoRA/QLoRA adapter'

        # Datasets
        'datasets:Manage the 50 use-case training datasets'

        # Security
        'vault:Encrypted secrets vault management'
        'security:Security rules engine'

        # Optimization
        'optimizer:Multi-model cost optimization'
        'strategy:Model routing strategy engine'

        # Hardware and local LLMs
        'hardware:Hardware detection and runtime recommendation'
        'ollama:Ollama local LLM management'
        'llamacpp:llama.cpp local LLM management'

        # Enterprise services
        'dashboard:Enterprise web dashboard'
        'wizard:Assessment web wizard'
        'router:Model router proxy'
        'orchestrator:Multi-agent orchestration'
        'memory:Conversation memory service'
        'rag:RAG pipeline service'

        # Billing and skills
        'billing:Cost analytics and alerting'
        'skills:Skills marketplace'
        'adapter:LoRA adapter selector'

        # Operations
        'health:Run agent health checks'
        'logs:Tail agent logs'
        'status:Show status of all agents'
        'help:Show help message'

        # Completions
        'completions:Shell completion scripts'
    )

    # If we are on the first argument, complete the top-level command
    if (( CURRENT == 2 )); then
        _describe 'command' top_commands
        return
    fi

    # Route to subcommand-specific completion
    case "${words[2]}" in
        # Agent commands: complete deployment methods
        zeroclaw|nanoclaw|picoclaw|openclaw|parlant)
            if (( CURRENT == 3 )); then
                _claw_agent_methods
            fi
            ;;

        # deploy / validate: --assessment <file>
        deploy|validate)
            _arguments \
                '--assessment[Assessment JSON file]:file:_files -g "*.json"'
            ;;

        # finetune: --assessment <file> | --adapter <name> [--dry-run]
        finetune)
            _arguments \
                '--assessment[Assessment JSON file]:file:_files -g "*.json"' \
                '--adapter[Pre-built adapter config name]:adapter:' \
                '--dry-run[Validate only, do not train]'
            ;;

        # datasets: --list | --validate | --download-all
        datasets)
            _arguments \
                '--list[List all 50 use-case datasets with status]' \
                '--validate[Validate all datasets (rows, schema, license)]' \
                '--download-all[Download all 50 datasets]'
            ;;

        # Commands with their own subcommands
        vault)        _claw_vault ;;
        security)     _claw_security ;;
        optimizer)    _claw_optimizer ;;
        strategy)     _claw_strategy ;;
        hardware)     _claw_hardware ;;
        ollama)       _claw_ollama ;;
        llamacpp)     _claw_llamacpp ;;
        dashboard)    _claw_dashboard ;;
        wizard)       _claw_wizard ;;
        router)       _claw_router ;;
        orchestrator) _claw_orchestrator ;;
        memory)       _claw_memory ;;
        rag)          _claw_rag ;;
        billing)      _claw_billing ;;
        skills)       _claw_skills ;;
        adapter)      _claw_adapter ;;

        # health: agent or "all"
        health)
            if (( CURRENT == 3 )); then
                _claw_agents_or_all
            fi
            ;;

        # logs: agent name
        logs)
            if (( CURRENT == 3 )); then
                _claw_agents
            fi
            ;;

        # completions: bash | zsh | install
        completions)
            if (( CURRENT == 3 )); then
                local -a comp_cmds=(
                    'bash:Print bash completion script to stdout'
                    'zsh:Print zsh completion script to stdout'
                    'install:Install completions to system directories'
                )
                _describe 'completions command' comp_cmds
            fi
            ;;

        # status, help: no further completions
        status|help) ;;
    esac
}

_claw "$@"
