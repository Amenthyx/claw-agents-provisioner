{
  "base_model": "mistralai/Mistral-7B-v0.3",
  "method": "qlora",
  "rank": 32,
  "lora_alpha": 64,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "v_proj",
    "k_proj",
    "o_proj"
  ],
  "epochs": 3,
  "learning_rate": 0.0002,
  "batch_size": 4,
  "gradient_accumulation_steps": 4,
  "max_seq_length": 2048,
  "warmup_steps": 50,
  "logging_steps": 10,
  "save_steps": 200,
  "vram_estimate_gb": 10,
  "dataset_path": "finetune/datasets/50-personal-finance-budgeting/data.jsonl",
  "output_dir": "finetune/output/50-personal-finance-budgeting/"
}