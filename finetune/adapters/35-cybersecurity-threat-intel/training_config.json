{
  "base_model": "meta-llama/Meta-Llama-3.1-8B",
  "method": "qlora",
  "rank": 64,
  "lora_alpha": 128,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "v_proj",
    "k_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "epochs": 5,
  "learning_rate": 0.0001,
  "batch_size": 2,
  "gradient_accumulation_steps": 8,
  "max_seq_length": 2048,
  "warmup_steps": 100,
  "logging_steps": 10,
  "save_steps": 200,
  "vram_estimate_gb": 12,
  "dataset_path": "finetune/datasets/35-cybersecurity-threat-intel/data.jsonl",
  "output_dir": "finetune/output/35-cybersecurity-threat-intel/"
}
