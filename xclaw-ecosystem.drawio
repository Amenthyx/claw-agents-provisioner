        <mxCell id="sec_hw_box" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;arcSize=8;" value="" vertex="1">
          <mxGeometry height="130" width="440" x="940" y="148" as="geometry" />
        </mxCell>
        <mxCell id="sec_hw_t" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=11;fontColor=#ff6688;fontStyle=1;" value="HOW THE GATE WORKS" vertex="1">
          <mxGeometry height="18" width="400" x="960" y="152" as="geometry" />
        </mxCell>
        <mxCell id="sec_hw_d" parent="1" style="text;html=0;align=left;verticalAlign=top;fontSize=9;fontColor=#ccaaaa;spacingLeft=6;spacingTop=2;" value="1. Agent boot → SecurityChecker instantiated, rules loaded&#xa;2. ALL regex compiled once into RAM (not re-compiled per request)&#xa;3. IP ranges parsed into ip_network objects for O(1) CIDR lookup&#xa;4. INBOUND: check_url → check_content → detect_pii&#xa;5. OUTBOUND: mask_secrets → detect_pii → check_content&#xa;6. Violations → enforcement action + audit log entry&#xa;7. Config also generates system prompt appendix injected at boot&#xa;8. Two modes: Config generator (JSON) + Runtime validator (library)" vertex="1">
          <mxGeometry height="100" width="420" x="950" y="172" as="geometry" />
        </mxCell>
        <mxCell id="sec_ram_box" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="440" x="940" y="290" as="geometry" />
        </mxCell>
        <mxCell id="sec_ram_t" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=11;fontColor=#ff6688;fontStyle=1;" value="SECRETS IN RAM — Pre-Compiled Pattern Engine" vertex="1">
          <mxGeometry height="18" width="400" x="960" y="294" as="geometry" />
        </mxCell>
        <mxCell id="sec_ram_d" parent="1" style="text;html=0;align=left;verticalAlign=top;fontSize=9;fontColor=#ccaaaa;spacingLeft=6;spacingTop=2;" value="Held in memory only — never serialized to disk:&#xa;&#xa;_compiled_url_patterns[]       8 regex (bare IP, .onion, exploits...)&#xa;_compiled_injection_patterns[] 6 regex (prompt injection detectors)&#xa;_compiled_pii_patterns{}       8 named patterns (email, SSN, CC...)&#xa;_compiled_secret_patterns{}    16 named patterns (API keys, JWT...)&#xa;_blocked_networks[]            15 CIDR ranges as ip_network objects&#xa;&#xa;Total: 53 compiled patterns — O(1) per-request validation" vertex="1">
          <mxGeometry height="110" width="420" x="950" y="314" as="geometry" />
        </mxCell>
        <mxCell id="sec_dom_t" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=11;fontColor=#ff6688;fontStyle=1;" value="6 SECURITY DOMAINS" vertex="1">
          <mxGeometry height="18" width="400" x="960" y="444" as="geometry" />
        </mxCell>
        <mxCell id="domA" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;fontSize=8;fontColor=#ccaaaa;align=left;spacingLeft=6;spacingTop=2;" value="A. Forbidden URLs&#xa;50+ blocked domains&#xa;8 URL regex patterns&#xa;4 blocked TLDs (.onion .bit .i2p .loki)&#xa;URL shortener: resolve_and_check&#xa;Action: block_and_log" vertex="1">
          <mxGeometry height="86" width="215" x="940" y="466" as="geometry" />
        </mxCell>
        <mxCell id="domB" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;fontSize=8;fontColor=#ccaaaa;align=left;spacingLeft=6;spacingTop=2;" value="B. Content Rules&#xa;10 forbidden categories:&#xa;  MALWARE CREDENTIALS PII_EXFIL&#xa;  CSAM WEAPONS HARASSMENT&#xa;  FRAUD PRIVACY SAFETY_BYPASS&#xa;  ILLEGAL_SERVICES&#xa;6 injection detection patterns&#xa;Action: block_and_log" vertex="1">
          <mxGeometry height="110" width="215" x="1165" y="466" as="geometry" />
        </mxCell>
        <mxCell id="domC" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;fontSize=8;fontColor=#ccaaaa;align=left;spacingLeft=6;spacingTop=2;" value="C. Data Handling&#xa;8 PII detectors: email phone_us&#xa;  phone_intl ssn credit_card&#xa;  ipv4 passport iban&#xa;16 secret masks (see below)&#xa;Retention: conv 30d, PII 7d,&#xa;  logs 90d, audit 365d&#xa;8 prohibited data operations&#xa;Action: redact_and_warn" vertex="1">
          <mxGeometry height="118" width="215" x="940" y="560" as="geometry" />
        </mxCell>
        <mxCell id="domD" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;fontSize=8;fontColor=#ccaaaa;align=left;spacingLeft=6;spacingTop=2;" value="D. Behavioral Rules&#xa;Rate: 60 RPM/user, 500 RPH&#xa;Max: 100K tok/req, 32K resp&#xa;Max: 200 conv depth, 5 tools&#xa;10 scope restrictions&#xa;8 mandatory behaviors&#xa;8 forbidden actions&#xa;Action: block_and_log" vertex="1">
          <mxGeometry height="110" width="215" x="1165" y="584" as="geometry" />
        </mxCell>
        <mxCell id="domE" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;fontSize=8;fontColor=#ccaaaa;align=left;spacingLeft=6;spacingTop=2;" value="E. Network Rules&#xa;15 forbidden IP ranges (RFC1918+)&#xa;Allowed ports: 80 443 8080 8443&#xa;TLS 1.2+ required&#xa;DNS rebinding protection&#xa;10 allowed API hosts whitelist&#xa;Strip internal headers&#xa;Action: block_and_log" vertex="1">
          <mxGeometry height="110" width="215" x="940" y="686" as="geometry" />
        </mxCell>
        <mxCell id="domF" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#1f1015;strokeColor=#552233;fontSize=8;fontColor=#ccaaaa;align=left;spacingLeft=6;spacingTop=2;" value="F. Compliance&#xa;GDPR: 9 rules (erasure, DSAR,&#xa;  consent, data portability...)&#xa;HIPAA: 9 rules (PHI encrypt,&#xa;  BAA, breach notify, 15min timeout)&#xa;PCI-DSS: 7 rules (mask CC,&#xa;  no CVV storage, audit)&#xa;SOC2: 7 rules (access, monitoring)&#xa;Activated via CLAW_COMPLIANCE env" vertex="1">
          <mxGeometry height="120" width="215" x="1165" y="702" as="geometry" />
        </mxCell>
        <mxCell id="sec_secrets_t" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=11;fontColor=#ff6688;fontStyle=1;" value="16 SECRET MASKING PATTERNS" vertex="1">
          <mxGeometry height="18" width="400" x="960" y="836" as="geometry" />
        </mxCell>
        <mxCell id="sec_secrets_col1" parent="1" style="text;html=0;align=left;verticalAlign=top;fontSize=8;fontColor=#aa8888;fontFamily=Courier New;spacingLeft=6;" value="anthropic_key   sk-ant-*&#xa;openai_key      sk-*&#xa;openrouter_key  sk-or-*&#xa;deepseek_key    sk-*&#xa;groq_key        gsk_*&#xa;huggingface     hf_*&#xa;github_token    gh[ps]_*&#xa;aws_key         AKIA*" vertex="1">
          <mxGeometry height="110" width="210" x="940" y="858" as="geometry" />
        </mxCell>
        <mxCell id="sec_secrets_col2" parent="1" style="text;html=0;align=left;verticalAlign=top;fontSize=8;fontColor=#aa8888;fontFamily=Courier New;spacingLeft=6;" value="aws_secret      [A-Za-z0-9/+=]{40}&#xa;telegram_token  digits:token&#xa;discord_token   M/N prefix&#xa;slack_token     xox[bpasr]-*&#xa;generic_bearer  Bearer *&#xa;generic_passwd  key=value pairs&#xa;private_key     -----BEGIN...KEY-----&#xa;jwt             eyJ*.eyJ*.*" vertex="1">
          <mxGeometry height="110" width="230" x="1160" y="858" as="geometry" />
        </mxCell>
        <mxCell id="sec_secrets_note" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=9;fontColor=#ff3355;fontStyle=2;" value="All matches replaced with ***REDACTED*** — never reaches client or logs" vertex="1">
