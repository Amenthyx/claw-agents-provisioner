        <mxCell id="opt_pre_sub" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=9;fontColor=#888888;" value="claw_optimizer.py  |  Dashboard :9091  |  Sequential pipeline before LLM call" vertex="1">
