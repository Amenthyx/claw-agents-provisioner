        <mxCell id="opt_rules" parent="1" style="text;html=0;align=left;verticalAlign=top;fontSize=9;fontColor=#ccbbee;fontFamily=Courier New;spacingLeft=8;spacingTop=2;" value="R1  ConversationDedup       60s window — drop exact duplicates&#xa;R2  SemanticCache           0.85 cosine threshold, 3600s TTL&#xa;R3  TokenEstimator          Estimate cost before calling LLM&#xa;R4  ContextPruner           100K max tokens, 0.7 summary ratio&#xa;R5  PromptOptimizer         Compress/rewrite for fewer tokens&#xa;R6  BudgetEnforcer          $50/day  $200/week  $500/month&#xa;                            80% alert threshold, auto-downgrade&#xa;R7  TaskComplexityRouter    &lt;500 tok → budget, else premium&#xa;R8  LatencyRouter           (disabled) 2000ms threshold&#xa;R9  ProviderHealthScorer    Min 0.5 score, 60min window&#xa;R10 RateLimitManager        anthropic:50 openai:60&#xa;                            deepseek:100 gemini:60 RPM&#xa;R11 FallbackChain           Retry 429/500/502/503, 3 attempts" vertex="1">
          <mxGeometry height="190" width="400" x="452" y="526" as="geometry" />
        </mxCell>
