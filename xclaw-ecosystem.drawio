        <mxCell id="sec_in_d" parent="1" style="text;html=0;align=left;verticalAlign=top;fontSize=9;fontColor=#cc8899;spacingLeft=8;spacingTop=2;" value="check_url() — validate all URLs against 50+ blocked domains, 8 regex, 4 TLDs&#xa;check_content() — scan for 10 forbidden categories + 6 injection patterns&#xa;detect_pii() — flag 8 PII types (email, SSN, CC, phone, passport, IBAN, IPv4)&#xa;Rate limit: 120 RPM global, 60 RPM per user&#xa;&#xa;VIOLATION → block_and_log → return 403 + audit entry → request stopped" vertex="1">
