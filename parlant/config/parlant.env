# ===================================================================
# Parlant — Agent-Specific Environment Template
# ===================================================================
# These variables are Parlant-specific defaults.
# The entrypoint.sh translates unified CLAW_ vars into these.
# ===================================================================

# Parlant server
PARLANT_HOST=0.0.0.0
PARLANT_PORT=8800
PARLANT_MCP_PORT=8181
PARLANT_LOG_LEVEL=info

# LLM configuration (set by entrypoint from CLAW_ vars)
# PARLANT_LLM_PROVIDER=
# PARLANT_LLM_MODEL=
# PARLANT_LLM_API_KEY=
# PARLANT_LLM_API_BASE=

# Data persistence
PARLANT_DATA_DIR=/home/parlant/.parlant
PARLANT_DB_TYPE=sqlite

# Guidelines and behavior
PARLANT_GUIDELINES_DIR=/home/parlant/.parlant/guidelines
PARLANT_JOURNEYS_DIR=/home/parlant/.parlant/journeys

# Tool integration
PARLANT_TOOLS_ENABLED=true
PARLANT_MCP_ENABLED=true
