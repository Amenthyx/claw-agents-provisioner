# ===================================================================
# CLAW AGENTS PROVISIONER — UNIFIED ENV TEMPLATE
# ===================================================================
# Copy this file to .env and fill in YOUR values.
# Only fill the sections relevant to your chosen agent and LLM provider.
#
# Usage:
#   cp .env.template .env
#   $EDITOR .env          # Fill in your keys
#   ./claw.sh deploy      # Or: ./claw.sh <agent> docker
#
# IMPORTANT: Never commit .env to git. Only .env.template is tracked.
# ===================================================================


# =====================================================================
# LLM PROVIDER API KEYS
# =====================================================================
# Fill only the providers you intend to use. At least one is required.
# The entrypoint scripts will translate these to each agent's format.
# =====================================================================

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME
OPENROUTER_API_KEY=sk-or-REPLACE_ME
DEEPSEEK_API_KEY=sk-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
GROQ_API_KEY=gsk_REPLACE_ME
HUGGINGFACE_TOKEN=hf_REPLACE_ME


# =====================================================================
# CHAT CHANNEL TOKENS
# =====================================================================
# Fill only the channels your agent will use.
# =====================================================================

TELEGRAM_BOT_TOKEN=123456789:REPLACE_ME
DISCORD_BOT_TOKEN=REPLACE_ME
WHATSAPP_SESSION_DATA=
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_APP_TOKEN=xapp-REPLACE_ME
SIGNAL_PHONE_NUMBER=


# =====================================================================
# AGENT SELECTION
# =====================================================================
# These can be auto-filled by the assessment pipeline, or set manually.
# CLAW_AGENT determines which agent is deployed.
# CLAW_LLM_PROVIDER + CLAW_LLM_MODEL determine the LLM backend.
# =====================================================================

CLAW_AGENT=zeroclaw
# Options: zeroclaw | nanoclaw | picoclaw | openclaw

CLAW_LLM_PROVIDER=anthropic
# Options: anthropic | openai | openrouter | deepseek | gemini | groq

CLAW_LLM_MODEL=claude-sonnet-4-6
# Examples: claude-sonnet-4-6, claude-opus-4-6, gpt-4.1, deepseek-chat,
#           gemini-2.0-flash, mistral-large, llama-3.1-8b


# =====================================================================
# ASSESSMENT-DERIVED CONFIG
# =====================================================================
# These fields are populated by the assessment pipeline from the client
# intake form (client-assessment.json). They drive skills installation,
# compliance configuration, and fine-tuning decisions.
# =====================================================================

CLAW_CLIENT_NAME=
# Client or project display name (e.g., "Acme Corp")

CLAW_CLIENT_INDUSTRY=general
# From assessment client_profile.industry
# Examples: real-estate, e-commerce, healthcare, legal, finance,
#           education, manufacturing, technology, hospitality

CLAW_CLIENT_LANGUAGE=en
# Primary language code (ISO 639-1)
# Examples: en, es, de, fr, it, pt, nl, zh, ja, ko, ar

CLAW_DATA_SENSITIVITY=medium
# Options: low | medium | high | critical
# Drives encryption and storage decisions in agent config

CLAW_STORAGE_PREFERENCE=local
# Options: local | private-cloud | any-cloud
# Determines where agent stores data and conversation logs

CLAW_COMPLIANCE=none
# Options: none | gdpr | hipaa | soc2 | pci-dss
# Multiple: comma-separated (e.g., gdpr,soc2)
# Configures audit logging, data retention, encryption

CLAW_SKILLS=
# Comma-separated list of skills to install from the skills catalog
# Examples: whatsapp-business,lead-qualifier,auto-follow-up
#           email-manager,calendar-sync,web-search
#           code-reviewer,git-manager,ci-cd-monitor
# Full catalog: see assessment/claw-client-assessment/benchmarks/skills-catalog.json


# =====================================================================
# FINE-TUNING CONFIG
# =====================================================================
# Controls LoRA/QLoRA adapter training and loading.
# For API-only models (Claude, GPT, DeepSeek), use system prompt
# enrichment instead of adapter loading.
# =====================================================================

CLAW_FINETUNE_ENABLED=false
# Set to true to trigger adapter training during deployment

CLAW_FINETUNE_METHOD=qlora
# Options: lora | qlora
# qlora = 4-bit quantized, requires less VRAM (8-16 GB)
# lora  = full precision, requires more VRAM (24+ GB)

CLAW_FINETUNE_BASE_MODEL=mistralai/Mistral-7B-v0.3
# Hugging Face model ID for the base model
# Options: mistralai/Mistral-7B-v0.3, meta-llama/Llama-3.1-8B,
#          microsoft/phi-3-mini-3.8b, Qwen/Qwen2.5-7B

CLAW_FINETUNE_RANK=32
# LoRA rank — higher = more capacity, more VRAM
# Options: 8, 16, 32, 64

CLAW_FINETUNE_EPOCHS=3
# Number of training epochs (typically 3-5)

CLAW_FINETUNE_LEARNING_RATE=2e-4
# Learning rate for adapter training

CLAW_FINETUNE_BATCH_SIZE=4
# Training batch size (reduce if OOM)

CLAW_ADAPTER_PATH=
# Path to a pre-built adapter directory (skips training)
# Example: ./finetune/adapters/02-real-estate/adapter_model/

CLAW_FINETUNE_USE_CASE=
# Use case ID for pre-built adapter configs
# Example: 01-customer-support, 02-real-estate, 07-code-review

CLAW_SYSTEM_PROMPT_ENRICHMENT=true
# For API-only models (Claude, GPT, DeepSeek) that cannot load adapters:
# Generates a rich system prompt with industry knowledge from the dataset


# =====================================================================
# AGENT-SPECIFIC OVERRIDES — ZeroClaw
# =====================================================================
# ZeroClaw: Rust-based agent. Config format: TOML (~/.zeroclaw/config.toml)
# Docs: https://github.com/zeroclaw-labs/zeroclaw
# =====================================================================

ZEROCLAW_VERSION=latest
# Release tag or "latest". Examples: v0.5.2, latest

ZEROCLAW_INSTALL_METHOD=binary
# Options: binary | source
# binary = download pre-built release (fast, recommended)
# source = build from source (requires 4+ GB RAM, Rust toolchain)

ZEROCLAW_EXTRA_TOML=
# Additional TOML config to append to config.toml
# Use for advanced overrides not covered by unified vars
# Example: '[tools]\nenabled = ["web_search", "file_manager"]'

ZEROCLAW_LOG_LEVEL=info
# Options: trace | debug | info | warn | error


# =====================================================================
# AGENT-SPECIFIC OVERRIDES — NanoClaw
# =====================================================================
# NanoClaw: TypeScript agent. No config file — code-driven via Claude Code.
# Configured by patching source with sed/envsubst before build.
# Docs: https://github.com/qwibitai/nanoclaw
# =====================================================================

NANOCLAW_CHANNEL=telegram
# Primary chat channel
# Options: telegram | discord | whatsapp | slack | signal

NANOCLAW_SANDBOX_RUNTIME=docker
# Container runtime for agent sandboxing
# Options: docker | none
# NanoClaw uses Docker internally for code execution isolation

NANOCLAW_MAX_MEMORY_MB=512
# Memory limit for the NanoClaw container (MB)


# =====================================================================
# AGENT-SPECIFIC OVERRIDES — PicoClaw
# =====================================================================
# PicoClaw: Go-based agent. Config format: JSON (~/.picoclaw/config.json)
# Docs: https://github.com/sipeed/picoclaw
# =====================================================================

PICOCLAW_VERSION=latest
# Release tag or "latest". Examples: v0.2.0, latest

PICOCLAW_GATEWAY_HOST=0.0.0.0
# Host to bind the PicoClaw gateway HTTP server

PICOCLAW_GATEWAY_PORT=8080
# Port for the PicoClaw gateway

PICOCLAW_LOG_LEVEL=info
# Options: debug | info | warn | error


# =====================================================================
# AGENT-SPECIFIC OVERRIDES — OpenClaw
# =====================================================================
# OpenClaw: TypeScript/Node.js agent. Config: JSON5 (~/.openclaw/openclaw.json)
# Heaviest agent (~1.5 GB RAM). Most integrations (13+ channels).
# Docs: https://docs.openclaw.ai
# =====================================================================

OPENCLAW_VERSION=latest
# Release tag or "latest". Examples: v4.5.0, latest

OPENCLAW_DM_POLICY=pairing
# Direct message routing policy
# Options: pairing | queue | round-robin

OPENCLAW_PORT=3000
# Port for the OpenClaw web interface / API

OPENCLAW_LOG_LEVEL=info
# Options: debug | info | warn | error

OPENCLAW_EXTRA_JSON5=
# Additional JSON5 config to merge into openclaw.json
# Use for advanced overrides not covered by unified vars
