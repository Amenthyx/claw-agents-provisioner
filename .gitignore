finetune/runs/
finetune/outputs/
*.safetensors
*.bin
*.pt
*.pth
!finetune/datasets/**
!finetune/adapters/**

# Vagrant
.vagrant/

# Docker
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

