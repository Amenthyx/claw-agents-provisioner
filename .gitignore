# ===================================================================
# CLAW AGENTS PROVISIONER — GITIGNORE
# ===================================================================

# Environment files (contain API keys)
.env
.env.local
.env.*.local

# Watchdog config (contains bot tokens)
watchdog.json

# Vault files (encrypted secrets)
secrets.vault
secrets.*.vault
.env.config

# Security rules (may contain custom overrides)
security_rules.json

# Optimizer databases
cost_log.sqlite3
response_cache.sqlite3
budget_tracking.sqlite3
cost_log.jsonl
optimizer.log

# Strategy engine outputs
strategy.json
strategy_config.json

# Hardware detection output
hardware_profile.json

# Client assessment files (contain PII)
client-assessment*.json
!client-assessment.example.json

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
dist/
build/

# Fine-tuning outputs (trained weights — large files)
finetune/runs/
finetune/outputs/
*.safetensors
*.bin
*.pt
*.pth
!finetune/datasets/**
!finetune/adapters/**

# Vagrant
.vagrant/

# Docker
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node (for agents that use it)
node_modules/

# Data directory (runtime data — billing, memory, RAG, etc.)
data/memory/
data/billing/
data/rag/
data/router/
data/orchestrator/
data/skills/
data/dashboard/
data/wizard/
!data/.gitkeep

# Wizard UI build artifacts
wizard-ui/dist/
wizard-ui/node_modules/

# Secret rotation (runtime data)
rotation-policy.json
logs/rotation-audit.jsonl

# Security scan reports (generated)
security-reports/

# detect-secrets baseline
.secrets.baseline
